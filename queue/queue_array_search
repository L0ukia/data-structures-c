#include <stdio.h>
#include <stdlib.h>
#include <stdbool.h>

#define QueueLimit 101

typedef int QueueElementType;

typedef struct {
    int Front;
    int Rear;
    QueueElementType Element[QueueLimit];
} QueueType;


void CreateQ(QueueType *Queue);
bool EmptyQ(QueueType Queue);
bool FullQ(QueueType Queue);
void RemoveQ(QueueType *Queue, QueueElementType *Item);
void AddQ(QueueType *Queue, QueueElementType Item);

bool SearchQ(QueueType *Queue, QueueElementType Item);
void TraverseQ(QueueType Queue);


int main() {
    QueueType myQueue;
    QueueElementType searchItem;
    int i;

    CreateQ(&myQueue);
    for (i = 1; i <= 100; i++) {
        if (i % 3 == 0) {
            AddQ(&myQueue, i);
        }
    }

    TraverseQ(myQueue);


    printf("Give the search value: ");
    scanf("%d", &searchItem);

    if (SearchQ(&myQueue, searchItem)) {
        printf("Found\n");
    } else {
        printf("Not Found\n");
    }

    TraverseQ(myQueue);

    return 0;
}

bool SearchQ(QueueType *Queue, QueueElementType Item) {
    QueueElementType currentElement;
    bool found = false;
    while (!EmptyQ(*Queue) && !found) {
        RemoveQ(Queue, &currentElement);
        if (currentElement == Item) {
            found = true;
        }
    }
    return found;
}


void CreateQ(QueueType *Queue) {
    Queue->Front = 0;
    Queue->Rear = 0;
}

bool EmptyQ(QueueType Queue) {
    return (Queue.Front == Queue.Rear);
}

bool FullQ(QueueType Queue) {
    return (Queue.Front == ((Queue.Rear + 1) % QueueLimit));
}

void RemoveQ(QueueType *Queue, QueueElementType *Item) {
    if (!EmptyQ(*Queue)) {
        *Item = Queue->Element[Queue->Front];
        Queue->Front = (Queue->Front + 1) % QueueLimit;
    } else {
        printf("Empty Queue\n");
    }
}

void AddQ(QueueType *Queue, QueueElementType Item) {
    if (!FullQ(*Queue)) {
        Queue->Element[Queue->Rear] = Item;
        Queue->Rear = (Queue->Rear + 1) % QueueLimit;
    } else {
        printf("Full Queue\n");
    }
}

void TraverseQ(QueueType Queue) {
    int current;
    if (!EmptyQ(Queue)) {
        current = Queue.Front;
        while (current != Queue.Rear) {
            printf("%d ", Queue.Element[current]);
            current = (current + 1) % QueueLimit;
        }
        printf("\n");
    } else {
        printf("Empty Queue\n");
    }
}
